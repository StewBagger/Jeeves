# ============================================================================
# JeevesBot Configuration
# Copy this file to config.env and fill in your values.
# ============================================================================

# RCON Settings (must match your PZ server's RCON config)
RCON_HOST=127.0.0.1
RCON_PORT=27015
RCON_PASSWORD=YourRCONPassword

# Discord Settings
DISCORD_TOKEN=YourBotToken
DISCORD_CHANNEL_ID=YourChannelID
DISCORD_GUILD_ID=YourGuildID

# Server Paths (REQUIRED — adjust to your server installation)
SERVER_BATCH=C:\path\to\StartServer64.bat
SERVER_INI_PATH=C:\Users\YourUser\Zomboid\Server\YourServer.ini
MODS_FOLDER_PATH=C:\SteamCMD\steamapps\common\Project Zomboid Dedicated Server\steamapps\workshop\content\108600

# Mod Update Log (bot stores mod update timestamps here)
UPDATE_LOG_PATH=C:\path\to\mod_update_log.json

# Server Process Name (used for crash detection — usually java.exe on Windows)
SERVER_PROCESS_NAME=java.exe

# Startup Timing (optional — increase for heavily modded servers)
# STARTUP_WAIT: seconds to wait after launching before polling RCON (default: 120)
# CHECK_INTERVAL: seconds between RCON retry attempts (default: 30)
# MONITOR_RETRIES: number of RCON retries before giving up (default: 20)
# STARTUP_WAIT=120
# CHECK_INTERVAL=30
# MONITOR_RETRIES=20

# SteamCMD (used by /update command)
STEAMCMD_PATH=C:\SteamCMD\steamcmd.exe

# Role Settings (Discord role names required to use admin commands)
DEFAULT_ROLE=Admin
RANK_1=Fuel
RANK_2=Spark
RANK_3=Cinder
RANK_4=Flame
RANK_5=Blaze
RANK_6=Inferno

# Chat Relay (bridges in-game chat with a Discord channel)
CHAT_RELAY_CHANNEL_ID=YourChatRelayChannelID
CHAT_LOG_PATH=C:\Users\YourUser\Zomboid\Logs

# Player Tracker (path to the PZ server Logs folder)
USER_LOG_PATH=C:\Users\YourUser\Zomboid\Logs

# Custom Emojis (optional — leave blank for default Unicode emoji)
# Upload custom emoji to your Discord server and paste the full string here.
# Format: <:name:ID> for static, <a:name:ID> for animated
# EMOJI_HAPPY=<:pzhappy:1234567890>
# EMOJI_DIZZY=<:pzdizzy:1234567890>
# EMOJI_PANIC=<:pzpanic:1234567890>
# EMOJI_ANGRY=<:pzangry:1234567890>
# EMOJI_JEEVES=<:jeeves:1234567890>
# EMOJI_SPIFFO_POP=<a:spiffopop:1234567890>
# EMOJI_SPIFFO_WAVE=<:spiffowave:1234567890>
# EMOJI_SPIFFO_EDUCATE=<:spiffoeducate:1234567890>
# EMOJI_SPIFFO_KATANA=<:spiffokatana:1234567890>
# EMOJI_SPIFFO_STOP=<:spiffostop:1234567890>

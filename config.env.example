# Project Zomboid Discord Bot Configuration

# RCON Settings
RCON_HOST=127.0.0.1
RCON_PORT=27015
RCON_PASSWORD=YourRCONPassword

# Discord Settings
DISCORD_TOKEN=YourBotToken
DISCORD_CHANNEL_ID=YourChannelID
DISCORD_GUILD_ID=YourGuildID

# Server Paths
SERVER_BATCH=C:\SteamCMD\steamapps\common\Project Zomboid Dedicated Server\StartServer64.bat

# Mod Checker
STEAM_API_KEY=YourSteamAPIKey
SERVER_INI_PATH=C:\Users\ut2k3\Zomboid\Server\Jeeves.ini
UPDATE_LOG_PATH=C:\Users\ut2k3\Desktop\Mod Update Log\mod_update_log.json

# Mod Cleanup (Steam Workshop content folder for Project Zomboid - 108600 is the game's Steam ID)
MODS_FOLDER_PATH=C:\SteamCMD\steamapps\common\Project Zomboid Dedicated Server\steamapps\workshop\content\108600

# JeevesAlerts Mod (path to the mod's shared Lua folder for rank data)
JEEVES_MOD_PATH=C:\path\to\JeevesAlerts\Contents\mods\JeevesAlerts\42\media\lua\shared

# Role Settings (Discord role names required to use commands)
DEFAULT_ROLE=PZ Server Commands
RANK_1=Fuel
RANK_2=Spark
RANK_3=Cinder
RANK_4=Flame
RANK_5=Blaze
RANK_6=Inferno

# Chat Relay (bridges in-game chat with a Discord channel)
CHAT_RELAY_CHANNEL_ID=YourChatRelayChannelID
CHAT_LOG_PATH=C:\Users\ut2k3\Zomboid\Logs

# Player Tracker (path to the PZ server Logs folder containing *_user.txt files)
USER_LOG_PATH=C:\Users\ut2k3\Zomboid\Logs
